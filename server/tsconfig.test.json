{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "rootDir": ".",
        "noUnusedLocals": false,
        "noUnusedParameters": false,
        "noEmit": true,
        "isolatedModules": true,
        "declaration": false,
        "sourceMap": false,
        "types": ["jest", "node"]
    },
    "include": [
        "src/**/*.ts",
        "src/**/*.test.ts",
        "src/**/*.spec.ts"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "src/generated"
    ]
}
